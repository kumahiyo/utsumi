    {% if app.request.get('_route') == 'product_detail' or app.request.get('_route') == 'product_list' %}
      {% set Categories = group_categories() %}
      {% set isTreatMenu = false %}
    
      {% if app.request.get('_route') == 'product_detail' %}
          {% set pagename = '商品詳細' %}
      {% elseif app.request.get('_route') == 'product_list' %}
          {% set pagename = '商品一覧' %}
          {% set isTreatMenu = is_treat_menu(app.request.get('category_id')) %}
          {% if isTreatMenu == true %}
            {% set Categories = child_category_by_id(app.request.get('category_id')) %}
          {% endif %}
      {% else %}
          {% set pagename = '' %}
      {% endif %}
    
      {% macro tree(Category) %}
          {% from _self import tree %}
          <a href="{{ url('product_list') }}?category_id={{ Category.id }}">
              {{ Category.name }}
          </a>
          {#
          {% if Category.children|length > 0 %}
              <ul>
                  {% for ChildCategory in Category.children %}
                      <li>
                          {{ tree(ChildCategory) }}
                      </li>
                  {% endfor %}
              </ul>
          {% endif %}
          #}
      {% endmacro %}
    
      {# @see https://github.com/bolt/bolt/pull/2388 #}
      {% from _self import tree %}
    
      <section class="underImage--UT">
        <div class="L-inner">
          <h2>{{ pagename }}</h2>
         </div>
      </section>
    
      <div class="ec-categoryNaviRole">
          <div class="ec-itemNav">
              <ul class="ec-itemNav__nav">
                  {% if isTreatMenu == true %}
                    {% for Category in Categories %}
                        <li>
                            {{ tree(Category) }}
                        </li>
                    {% endfor %}
                  {% else %}
                    {% for Category in Categories %}
                        <li>
                            {{ tree(Category) }}
                        </li>
                    {% endfor %}
                  {% endif %}
              </ul>
          </div>
      </div>
    {% endif %}